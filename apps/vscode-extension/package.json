{
  "name": "ai-editor-vscode-extension",
  "displayName": "AI Editor",
  "description": "Agentic AI pair programmer: spec-first task planning, shadow-workspace patch review, and an inline chat controller — with a managed local runtime (no separate backend setup required).",
  "version": "0.1.0",
  "publisher": "ai-editor",
  "icon": "resources/icon.png",
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepA2125/shadow-forge.git"
  },
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:aiEditor.startTask",
    "onCommand:aiEditor.openReviewPanel",
    "onCommand:aiEditor.acceptPatch",
    "onCommand:aiEditor.rejectPatch",
    "onCommand:aiEditor.refreshTask",
    "onCommand:aiEditor.attachToTask",
    "onCommand:aiEditor.openChat",
    "onCommand:aiEditor.openMemoryPanel",
    "onCommand:aiEditor.runSetup",
    "onCommand:aiEditor.openSettingsPanel",
    "onCommand:aiEditor.restartBackend",
    "onCommand:aiEditor.mcpAddServer",
    "onCommand:aiEditor.mcpListServers",
    "onWebviewPanel:aiEditorChat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiEditor.startTask",
        "title": "AI Editor: Start Task"
      },
      {
        "command": "aiEditor.openReviewPanel",
        "title": "AI Editor: Open Review (Chat)"
      },
      {
        "command": "aiEditor.acceptPatch",
        "title": "AI Editor: Accept Patch"
      },
      {
        "command": "aiEditor.rejectPatch",
        "title": "AI Editor: Reject Patch"
      },
      {
        "command": "aiEditor.refreshTask",
        "title": "AI Editor: Refresh Task"
      },
      {
        "command": "aiEditor.attachToTask",
        "title": "AI Editor: Attach to Task"
      },
      {
        "command": "aiEditor.openChat",
        "title": "AI Editor: Open Chat"
      },
      {
        "command": "aiEditor.openMemoryPanel",
        "title": "AI Editor: Open Memory Inspector"
      },
      {
        "command": "aiEditor.runSetup",
        "title": "AI Editor: Run Setup"
      },
      {
        "command": "aiEditor.openSettingsPanel",
        "title": "AI Editor: Open Settings"
      },
      {
        "command": "aiEditor.restartBackend",
        "title": "AI Editor: Restart Backend"
      },
      {
        "command": "aiEditor.mcpAddServer",
        "title": "AI Editor: Add MCP Server"
      },
      {
        "command": "aiEditor.mcpListServers",
        "title": "AI Editor: List MCP Servers"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "aiEditor.startTask",
          "when": "aiEditor.taskSubsystemEnabled"
        },
        {
          "command": "aiEditor.openMemoryPanel",
          "when": "aiEditor.memoryEnabled"
        }
      ]
    },
    "configuration": {
      "title": "AI Editor",
      "properties": {
        "aiEditor.backendBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Leave default for the managed backend; set explicitly to attach to a dev backend (e.g. one started via start-backend.sh)."
        },
        "aiEditor.defaultMode": {
          "type": "string",
          "default": "project_edit",
          "enum": [
            "inline",
            "file_edit",
            "project_edit",
            "autonomous"
          ],
          "description": "Default orchestration mode for submitted tasks."
        },
        "aiEditor.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 250,
          "description": "Polling interval used while a task is running."
        },
        "aiEditor.managedRuntime.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Provision and spawn the AI Editor runtime (backend, indexer, ripgrep, language servers) automatically per workspace. Disable to fall back to the pure dev flow (start-backend.sh + an explicit aiEditor.backendBaseUrl)."
        },
        "aiEditor.policy.shell": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "allow_all"
          ],
          "description": "Shell command policy for the execution agent's run_command tool. 'ask' surfaces an approval card for every command; 'allow_all' skips the gate."
        },
        "aiEditor.policy.scope": {
          "type": "string",
          "default": "ask",
          "enum": [
            "strict",
            "ask",
            "auto"
          ],
          "description": "Scope-extension policy for out-of-plan file writes. 'ask' pauses for approval; 'strict' auto-rejects; 'auto' silently approves and audit-logs."
        },
        "aiEditor.memory.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the cross-session memory harness (compaction, recall, consolidation). Requires a managed restart to take effect."
        },
        "aiEditor.memory.reranker": {
          "type": "boolean",
          "default": false,
          "description": "Enable the cross-encoder reranker for memory recall (requires aiEditor.memory.enabled). Requires a managed restart to take effect."
        }
      }
    }
  },
  "scripts": {
    "webview:build": "npm --prefix webview-ui run build",
    "webview:test": "npm --prefix webview-ui test",
    "prebuild": "npm --prefix webview-ui install && npm --prefix webview-ui run build",
    "build": "tsc -p tsconfig.json --noEmit && node esbuild.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-editor/editor-client": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.27.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
