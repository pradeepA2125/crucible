{
  "name": "crucible-vscode-extension",
  "displayName": "Crucible",
  "description": "Agentic AI pair programmer: spec-first task planning, shadow-workspace patch review, and an inline chat controller — with a managed local runtime (no separate backend setup required).",
  "version": "0.4.3",
  "publisher": "crucible-editor",
  "icon": "resources/icon.png",
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepA2125/crucible.git"
  },
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:crucible.startTask",
    "onCommand:crucible.openReviewPanel",
    "onCommand:crucible.acceptPatch",
    "onCommand:crucible.rejectPatch",
    "onCommand:crucible.refreshTask",
    "onCommand:crucible.attachToTask",
    "onCommand:crucible.openChat",
    "onCommand:crucible.openMemoryPanel",
    "onCommand:crucible.openGraphPanel",
    "onCommand:crucible.runSetup",
    "onCommand:crucible.openSettingsPanel",
    "onCommand:crucible.restartBackend",
    "onCommand:crucible.mcpAddServer",
    "onCommand:crucible.mcpListServers",
    "onWebviewPanel:crucibleChat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crucible.startTask",
        "title": "Crucible: Start Task"
      },
      {
        "command": "crucible.openReviewPanel",
        "title": "Crucible: Open Review (Chat)"
      },
      {
        "command": "crucible.acceptPatch",
        "title": "Crucible: Accept Patch"
      },
      {
        "command": "crucible.rejectPatch",
        "title": "Crucible: Reject Patch"
      },
      {
        "command": "crucible.refreshTask",
        "title": "Crucible: Refresh Task"
      },
      {
        "command": "crucible.attachToTask",
        "title": "Crucible: Attach to Task"
      },
      {
        "command": "crucible.openChat",
        "title": "Crucible: Open Chat",
        "icon": "$(sparkle)"
      },
      {
        "command": "crucible.openMemoryPanel",
        "title": "Crucible: Open Memory Inspector"
      },
      {
        "command": "crucible.openGraphPanel",
        "title": "Crucible: Open Dependency Space (AXON)"
      },
      {
        "command": "crucible.runSetup",
        "title": "Crucible: Run Setup"
      },
      {
        "command": "crucible.openSettingsPanel",
        "title": "Crucible: Open Settings"
      },
      {
        "command": "crucible.restartBackend",
        "title": "Crucible: Restart Backend"
      },
      {
        "command": "crucible.mcpAddServer",
        "title": "Crucible: Add MCP Server"
      },
      {
        "command": "crucible.mcpListServers",
        "title": "Crucible: List MCP Servers"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "crucible.startTask",
          "when": "crucible.taskSubsystemEnabled"
        },
        {
          "command": "crucible.openMemoryPanel",
          "when": "crucible.memoryEnabled"
        }
      ],
      "editor/title": [
        {
          "command": "crucible.openChat",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "Crucible",
      "properties": {
        "crucible.backendBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Leave default for the managed backend; set explicitly to attach to a dev backend (e.g. one started via start-backend.sh)."
        },
        "crucible.defaultMode": {
          "type": "string",
          "default": "project_edit",
          "enum": [
            "inline",
            "file_edit",
            "project_edit",
            "autonomous"
          ],
          "description": "Default orchestration mode for submitted tasks."
        },
        "crucible.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 250,
          "description": "Polling interval used while a task is running."
        },
        "crucible.managedRuntime.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Provision and spawn the Crucible runtime (backend, indexer, ripgrep, language servers) automatically per workspace. Disable to fall back to the pure dev flow (start-backend.sh + an explicit crucible.backendBaseUrl)."
        },
        "crucible.policy.shell": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "allow_all"
          ],
          "description": "Shell command policy for the execution agent's run_command tool. 'ask' surfaces an approval card for every command; 'allow_all' skips the gate."
        },
        "crucible.policy.scope": {
          "type": "string",
          "default": "ask",
          "enum": [
            "strict",
            "ask",
            "auto"
          ],
          "description": "Scope-extension policy for out-of-plan file writes. 'ask' pauses for approval; 'strict' auto-rejects; 'auto' silently approves and audit-logs."
        },
        "crucible.memory.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the cross-session memory harness (compaction, recall, consolidation). Requires a managed restart to take effect."
        },
        "crucible.memory.reranker": {
          "type": "boolean",
          "default": true,
          "description": "Enable the cross-encoder reranker for memory recall (requires crucible.memory.enabled). Requires a managed restart to take effect."
        }
      }
    }
  },
  "scripts": {
    "webview:build": "npm --prefix webview-ui run build",
    "webview:test": "npm --prefix webview-ui test",
    "prebuild": "npm --prefix webview-ui install && npm --prefix webview-ui run build",
    "build": "tsc -p tsconfig.json --noEmit && node esbuild.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@crucible/editor-client": "0.4.3",
    "extract-zip": "^2.0.1",
    "tar": "^7.5.19"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.27.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
